<% layout("layouts/boilerplate") %>

<div class="cart-page">

    <div class="cart-container">

        <h1 class="cart-heading">Your Order</h1>

        <% let total = 0; %>

        <% if (card && card.length > 0) { %>

            <div class="products-section">

                <% for (let item of card) { %>

                    <% total += Number(item.price); %>

                    <div class="product-card">

                        <div class="product-image-section">

                            <img
                                src="<%= item.image %>"
                                alt="<%= item.title %>"
                                class="product-image"
                            >

                        </div>

                        <div class="product-information">

                            <h2 class="product-title">
                                <%= item.title %>
                            </h2>

                            <p class="product-price">
                                ₹<%= item.price %>
                            </p>

                        </div>

                        <div class="delete-section">

                            <form
                                action="/cart/<%= item._id %>?_method=DELETE"
                                method="POST"
                            >

                                <button
                                    type="submit"
                                    class="delete-button"
                                    onclick="return confirm('Are you sure you want to delete this item?')"
                                >
                                    <i class="fa-solid fa-trash"></i>
                                    Delete
                                </button>

                            </form>

                        </div>

                    </div>

                <% } %>

            </div>

            <button
                type="button"
                class="proceed-button"
                onclick="showOrderInformation()"
            >
                Proceed to Checkout
            </button>

            <div class="order-card" id="orderInformation">

                <div class="order-header">

                    <div>
                        <p class="small-heading">ORDER DETAILS</p>
                        <h2>Order Information</h2>
                    </div>

                    <i class="fa-solid fa-receipt receipt-icon"></i>

                </div>

                <form action="/checkout" method="POST">

                    <div class="table-input-container">

                        <label for="tableNumber">
                            Table Number
                        </label>

                        <input
                            type="number"
                            id="tableNumber"
                            name="tableNumber"
                            placeholder="Enter your table number"
                            min="1"
                            required
                        >

                    </div>

                    <div class="bill-information">

                        <div class="bill-row">

                            <span>Total Items</span>

                            <span>
                                <%= card.length %>
                            </span>

                        </div>

                        <div class="bill-row">

                            <span>Subtotal</span>

                            <span>
                                ₹<%= total.toFixed(2) %>
                            </span>

                        </div>

                        <% let gst = total * 0.05; %>

                        <div class="bill-row">

                            <span>GST (5%)</span>

                            <span>
                                ₹<%= gst.toFixed(2) %>
                            </span>

                        </div>

                        <div class="bill-divider"></div>

                        <div class="bill-row final-total">

                            <span>Total Amount</span>

                            <span>
                                ₹<%= (total + gst).toFixed(2) %>
                            </span>

                        </div>

                    </div>

                    <input
                        type="hidden"
                        name="totalAmount"
                        value="<%= (total + gst).toFixed(2) %>"
                    >

                    <div class="payment-section">

                        <h3>Select Payment Method</h3>

                        <label class="payment-option">

                            <input
                                type="radio"
                                name="paymentMethod"
                                value="Cash"
                                required
                            >

                            <div class="payment-content">

                                <i class="fa-solid fa-money-bill-wave"></i>

                                <span>Cash</span>

                            </div>

                        </label>

                        <label class="payment-option">

                            <input
                                type="radio"
                                name="paymentMethod"
                                value="UPI"
                            >

                            <div class="payment-content">

                                <i class="fa-solid fa-mobile-screen"></i>

                                <span>UPI Payment</span>

                            </div>

                        </label>

                        <label class="payment-option">

                            <input
                                type="radio"
                                name="paymentMethod"
                                value="Card"
                            >

                            <div class="payment-content">

                                <i class="fa-solid fa-credit-card"></i>

                                <span>Credit / Debit Card</span>

                            </div>

                        </label>

                    </div>

                   <button
        type="submit"
        class="delete-button"
        onclick="return confirm('Are you sure you want to delete this item?')"
    >
        <i class="fa-solid fa-trash"></i>
        Delete
    </button>

                </form>

            </div>

        <% } else { %>

            <div class="empty-cart">

                <i class="fa-solid fa-cart-shopping"></i>

                <h2>Your cart is empty</h2>

                <p>
                    Add some delicious items to continue.
                </p>

                <a href="/" class="shopping-button">
                    Continue Shopping
                </a>

            </div>

        <% } %>

    </div>

</div>

<script>

    function showOrderInformation() {

        const orderCard = document.getElementById("orderInformation");

        orderCard.style.display = "block";

        orderCard.scrollIntoView({
            behavior: "smooth"
        });

    }

</script>