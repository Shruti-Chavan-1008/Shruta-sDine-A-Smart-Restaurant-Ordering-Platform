<% layout("layouts/boilerplate") %>

<style>
    .done-page {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: #f5f5f8;
    }

    .done-card {
        width: 100%;
        max-width: 650px;
        padding: 42px;
        background: white;
        border-radius: 22px;
        text-align: center;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.11);
    }

    .success-icon {
        width: 90px;
        height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 22px;
        border-radius: 50%;
        background: #e7f8ed;
        color: #168b46;
        font-size: 40px;
    }

    .success-label {
        margin: 0 0 9px;
        color: #168b46;
        font-size: 13px;
        font-weight: 850;
        letter-spacing: 1.5px;
    }

    .done-card h1 {
        margin: 0 0 14px;
        font-size: 32px;
    }

    .success-message {
        max-width: 480px;
        margin: 0 auto 28px;
        color: #777777;
        line-height: 1.7;
    }

    .order-summary {
        padding: 21px;
        background: #f8f7fc;
        border-radius: 14px;
        text-align: left;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 14px;
    }

    .summary-row:last-child {
        margin-bottom: 0;
    }

    .summary-row span {
        color: #707070;
    }

    .total-paid {
        color: #168b46;
        font-size: 19px;
    }

    .ordered-items {
        margin-top: 27px;
        text-align: left;
    }

    .ordered-items h3 {
        margin-bottom: 15px;
    }

    .ordered-item {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 12px;
        padding: 12px;
        background: #fafafa;
        border-radius: 12px;
    }

    .ordered-item img {
        width: 70px;
        height: 65px;
        border-radius: 10px;
        object-fit: cover;
    }

    .ordered-item h4 {
        margin: 0 0 6px;
    }

    .ordered-item p {
        margin: 0;
        color: #168b46;
        font-weight: 750;
    }

    .done-buttons {
        display: flex;
        gap: 13px;
        margin-top: 28px;
    }

    .done-buttons a {
        flex: 1;
        padding: 14px;
        border-radius: 11px;
        font-weight: 750;
        text-decoration: none;
    }

    .order-more-button {
        background: #9c3cff;
        color: white;
    }

    .home-button {
        border: 2px solid #9c3cff;
        color: #9c3cff;
    }

    @media (max-width: 500px) {
        .done-card {
            padding: 30px 20px;
        }

        .done-buttons {
            flex-direction: column;
        }
    }
</style>

<div class="done-page">

    <div class="done-card">

        <div class="success-icon">
            <i class="fa-solid fa-check"></i>
        </div>

        <p class="success-label">
            ORDER CONFIRMED
        </p>

        <h1>Your order has been placed!</h1>

        <p class="success-message">
            Your food is being prepared and will be served at
            table number <strong><%= tableNumber %></strong>.
        </p>

        <div class="order-summary">

            <div class="summary-row">
                <span>Table Number</span>
                <strong><%= tableNumber %></strong>
            </div>

            <div class="summary-row">
                <span>Payment Method</span>
                <strong><%= paymentMethod %></strong>
            </div>

            <div class="summary-row">
                <span>Subtotal</span>
                <strong>₹<%= subtotal.toFixed(2) %></strong>
            </div>

            <div class="summary-row">
                <span>GST</span>
                <strong>₹<%= gst.toFixed(2) %></strong>
            </div>

            <div class="summary-row">
                <span>Total Paid</span>

                <strong class="total-paid">
                    ₹<%= totalAmount.toFixed(2) %>
                </strong>
            </div>

        </div>

        <div class="ordered-items">

            <h3>Ordered Items</h3>

            <% orderedItems.forEach((item) => { %>

                <div class="ordered-item">

                    <img
                        src="<%= item.image %>"
                        alt="<%= item.title %>"
                    >

                    <div>
                        <h4><%= item.title %></h4>

                        <p>
                            ₹<%= Number(item.price).toFixed(2) %>
                        </p>
                    </div>

                </div>

            <% }); %>

        </div>

        <div class="done-buttons">

            <a href="/Menu" class="order-more-button">
                Order More
            </a>

            <a href="/hero" class="home-button">
                Back to Home
            </a>

        </div>

    </div>

</div>